FLASK_SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=sqlite:///instance/stress_app.sqlite

# Local defaults
PORT=8090
SOCKETIO_ASYNC_MODE=threading

# For production, set true when behind HTTPS.
SESSION_COOKIE_SECURE=false

# Email alerts. Gmail requires an app password.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Alert behavior
ALERT_COOLDOWN_SECONDS=300
FACE_SCORE_MAX_AGE_SECONDS=60
FACE_INFERENCE_MIN_INTERVAL_SECONDS=1.4
FACE_EWMA_ALPHA=0.55

# Hugging Face Inference Providers
HF_TOKEN=
HF_INFERENCE_PROVIDER=hf-inference
HF_FACE_EXPRESSION_MODEL=trpakov/vit-face-expression
HF_INFERENCE_TIMEOUT_SECONDS=30
HF_DIRECT_API_FALLBACK=true
